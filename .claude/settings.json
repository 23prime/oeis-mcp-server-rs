{
  "permissions": {
    "allow": [
      "Bash(uv run python:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push)",
      "Bash(git rev-parse HEAD)",
      "Bash(gh pr checks:*)",
      "Bash(gh run:*)",
      "Bash(mise run:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "mise run fix 2>&1 || true",
            "statusMessage": "Running fix..."
          }
        ]
      }
    ]
  }
}
